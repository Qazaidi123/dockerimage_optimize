pipeline {
  agent { label "${LABEL_NAME}" }

  stages {
    stage("Code") {
      steps {
        git url:"", branch:"main"
}
}
    stage("Build") {
      steps {
        sh " docker build -t $IMAGE_NAME:$IMAGE_TAG . "
}
}
    stage("image_Check") {
      steps {
        sh " trivy image --severity CRITICAL --exit-code 0 $IMAGE_NAME:$IMAGE_TAG "
} 
}
    stage("Image _Push") {
      steps {
        sh " echo $DOCKER_CREDS_PSW | docker login -u $DOCKER_CREDS_USR --password-stidn "
        sh " docker push $IMAGE_NAME:$IMAGE_TAG "
}
}
    stage("Deploy") {
      steps {
        sh " docker stop $CONTAINER_NAME || true "
        sh " docker rm $CONTAINER_NAME || true "
        sh " docker run -d --name $CONTAINER_NAME -p 80:5000 $IMAGE_NAME:$IMAGE_TAG "
}
}
}
}
